#!/usr/bin/env bash
# PATH-shim wrapper that routes `claude` through the current project's
# Nix devShell when one is available, and through the real `claude` binary
# otherwise. See the README for design notes.

set -eu

prog=claude-in-nix-devshell
self_realpath=$(readlink -f "$0")
self_dir=$(dirname "$self_realpath")

log() { [ "${CLAUDE_NIX_QUIET:-}" = "1" ] || echo "$prog: $*" >&2; }
warn() { echo "$prog: warning: $*" >&2; }
die() {
  echo "$prog: error: $1" >&2
  exit "${2:-1}"
}

# Validate a candidate path: must be executable, must not be the shim
# itself (avoid infinite recursion when several wrappers stack), and
# must exit 0 with non-empty stdout from `--version`. Echoes the
# version string on success; returns non-zero on any failure.
test_claude() {
  local candidate=$1 candidate_real version
  [ -x "$candidate" ] || return 1
  candidate_real=$(readlink -f "$candidate" 2>/dev/null) || candidate_real=$candidate
  [ "$candidate_real" = "$self_realpath" ] && return 1
  # Bound the probe — a stray `claude` binary that hangs shouldn't hang
  # the shim. `timeout` ships with coreutils, which the Nix wrapper
  # always prepends to PATH.
  if version=$(timeout 10 "$candidate" --version 2>/dev/null) && [ -n "$version" ]; then
    printf '%s' "$version"
    return 0
  fi
  return 1
}

# 1. Locate a working real-claude binary.
#
# Strategy:
#   a. If CLAUDE_NIX_EXECUTABLE is set (by the user, or by the Nix
#      `realClaude` build-time pin via wrapProgram --set-default), try it
#      first. On `--version` failure, fall through to a PATH scan rather
#      than aborting — a stale pin (binary moved, GC'd, replaced) should
#      not break invocation if a working claude exists elsewhere.
#   b. Otherwise (or as fallback), walk every PATH entry containing a
#      `claude` executable, skip the shim itself, and accept the first
#      one whose `--version` looks healthy. This lets users keep multiple
#      claude binaries on PATH (e.g. npm-installed + Homebrew) and the
#      wrapper picks whichever responds.
real_claude=
real_version=
source=

if [ -n "${CLAUDE_NIX_EXECUTABLE:-}" ]; then
  if real_version=$(test_claude "$CLAUDE_NIX_EXECUTABLE"); then
    real_claude=$CLAUDE_NIX_EXECUTABLE
    source=pinned
  else
    warn "CLAUDE_NIX_EXECUTABLE=$CLAUDE_NIX_EXECUTABLE failed --version probe; scanning PATH for a working fallback"
  fi
fi

if [ -z "$real_claude" ]; then
  IFS=: read -ra path_entries <<<"$PATH"
  for dir in "${path_entries[@]}"; do
    [ -n "$dir" ] || continue
    candidate=$dir/claude
    [ -e "$candidate" ] || continue
    if real_version=$(test_claude "$candidate"); then
      real_claude=$candidate
      source=PATH
      break
    fi
  done
fi

if [ -z "$real_claude" ]; then
  die "could not find a working Claude binary.
  shim path:  $self_realpath (this script — you are running the claude-in-nix-devshell wrapper)
  PATH:       $PATH
  pinned:     ${CLAUDE_NIX_EXECUTABLE:-<unset>}
  tried:      every 'claude' on PATH (excluding self); each was probed with '<candidate> --version'.
              a healthy claude exits 0 with non-empty stdout within 10s.

  fix one of:
    1. install Claude Code so 'claude' appears on PATH (npm install -g @anthropic-ai/claude-code,
       Homebrew, official installer, or a Nix derivation).
    2. set CLAUDE_NIX_EXECUTABLE=/absolute/path/to/claude in the calling environment.
    3. rebuild the wrapper with realClaude pinned:
         pkgs.callPackage \"\${claude-in-nix-devshell-src}/package.nix\" {
           realClaude = \"/opt/homebrew/bin/claude\";
         }" 127
fi

log "wrapping $real_claude ($real_version) [src: $source]"

# 2. Escape hatch.
if [ "${CLAUDE_NIX_DISABLE:-}" = "1" ]; then
  log "CLAUDE_NIX_DISABLE=1 set; skipping devShell logic and exec'ing real claude directly"
  exec "$real_claude" "$@"
fi

# 3. Anchor to the git toplevel; outside any repo, pass through.
root=$(git rev-parse --show-toplevel 2>/dev/null || true)
if [ -z "$root" ]; then
  log "not inside a git work tree; passing through to real claude without devShell"
  exec "$real_claude" "$@"
fi
cd "$root"

# 4. Honor user-supplied session flags; otherwise allocate.
session_id=""
inject_session=true
prev=""
for arg in "$@"; do
  case "$prev" in
  --resume) session_id="$arg" ;;
  esac
  case "$arg" in
  --continue | -c)
    inject_session=false
    break
    ;;
  --resume)
    inject_session=false
    ;;
  esac
  prev="$arg"
done
if $inject_session; then
  session_id=$(uuidgen | tr 'A-Z' 'a-z')
  set -- --session-id "$session_id" "$@"
fi

state_dir="${XDG_RUNTIME_DIR:-/tmp}"
export _CLAUDE_NIX_SESSION_ID="${session_id:-unknown}"
export _CLAUDE_NIX_FLAG="$state_dir/claude-in-nix-devshell-restart-$_CLAUDE_NIX_SESSION_ID"
export _CLAUDE_NIX_BASELINE="$state_dir/claude-in-nix-devshell-baseline-$_CLAUDE_NIX_SESSION_ID"
trap 'rm -f "$_CLAUDE_NIX_FLAG" "$_CLAUDE_NIX_BASELINE"' EXIT

# 5. Restart loop.
rc=0
while :; do
  if [ -e "$root/flake.nix" ] && nix develop --command true >/dev/null 2>&1; then
    nix develop --command "$real_claude" "$@" || rc=$?
  else
    "$real_claude" "$@" || rc=$?
  fi
  if [ -e "$_CLAUDE_NIX_FLAG" ]; then
    rm -f "$_CLAUDE_NIX_FLAG" "$_CLAUDE_NIX_BASELINE"
    set -- --resume "$_CLAUDE_NIX_SESSION_ID"
    continue
  fi
  exit "$rc"
done
